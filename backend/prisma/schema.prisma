generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id          String    @id @db.VarChar(10)
  name        String
  nameLower   String    @map("name_lower")
  countryId   String?   @map("country_id")
  countryName String?   @map("country_name")
  countryIso2 String?   @map("country_iso2") @db.VarChar(2)
  wpsRank     WpsRank?
  wpsScore    WpsScore?

  @@index([nameLower], map: "idx_person_name_lower")
  @@index([countryIso2], map: "idx_person_country_iso2")
  @@map("persons")
}

model WpsScore {
  personId String @id @map("person_id") @db.VarChar(10)
  score    Float
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([score], map: "idx_wps_score")
  @@map("wps_scores")
}

model WpsRank {
  personId String @id @map("person_id") @db.VarChar(10)
  rank     Int
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([rank], map: "idx_wps_rank")
  @@map("wps_ranks")
}

model Meta {
  key   String @id
  value String

  @@map("meta")
}

model LeaderboardEntry {
  personId     String   @id @map("person_id") @db.VarChar(10)
  name         String
  countryIso2  String?  @map("country_iso2") @db.VarChar(2)
  countryName  String?  @map("country_name")
  wps          Float
  globalRank   Int      @map("global_rank")
  countryRank  Int?     @map("country_rank")
  generatedAt  DateTime @map("generated_at")

  @@index([globalRank], map: "idx_leaderboard_global_rank")
  @@index([countryIso2, countryRank], map: "idx_leaderboard_country_rank")
  @@map("leaderboard_entries")
}

model HistorySnapshot {
  personId     String   @map("person_id") @db.VarChar(10)
  snapshotDate DateTime @map("snapshot_date") @db.Date
  wps          Float
  globalRank   Int      @map("global_rank")
  countryRank  Int?     @map("country_rank")

  @@id([personId, snapshotDate])
  @@map("history_snapshots")
}