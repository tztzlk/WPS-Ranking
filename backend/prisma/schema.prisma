generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id          String    @id @db.VarChar(10)
  name        String
  nameLower   String    @map("name_lower")
  countryId   String?   @map("country_id")
  countryName String?   @map("country_name")
  countryIso2 String?   @map("country_iso2") @db.VarChar(2)

  wpsScore WpsScore?
  wpsRank  WpsRank?

  @@index([nameLower], map: "idx_person_name_lower")
  @@index([countryIso2], map: "idx_person_country_iso2")
  @@map("persons")
}

model WpsScore {
  personId String @id @map("person_id") @db.VarChar(10)
  score    Float

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([score(sort: Desc)], map: "idx_wps_score_desc")
  @@map("wps_scores")
}

model WpsRank {
  personId String @id @map("person_id") @db.VarChar(10)
  rank     Int

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([rank], map: "idx_wps_rank_asc")
  @@map("wps_ranks")
}

model Meta {
  key   String @id
  value String

  @@map("meta")
}
