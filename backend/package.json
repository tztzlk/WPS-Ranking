{
  "name": "wps-ranking-backend",
  "version": "1.0.0",
  "description": "Backend API for WPS Ranking platform",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "leaderboard:update": "tsx src/scripts/updateLeaderboard.ts",
    "update:data": "tsx src/scripts/updateData.ts",
    "debug:person": "tsx src/scripts/debugFindPerson.ts",
    "db:push": "prisma db push",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "import:data": "tsx src/scripts/importData.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@vercel/og": "^0.9.0",
    "axios": "^1.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.35",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  }
}
