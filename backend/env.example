# === Required at runtime ===

# PostgreSQL connection string (pooled / PgBouncer).
# For Supabase: use the pooler URL on port 6543 with ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1"

PORT=5000
NODE_ENV=development

# Comma-separated allowed CORS origins.
# In production, set to your frontend URL(s).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# === Required at build / CLI time ===

# Direct PostgreSQL connection (bypasses PgBouncer).
# For Supabase: use the direct URL on port 5432 with ?sslmode=require
# Used by: prisma generate (postinstall), prisma db push, prisma migrate, import:data
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/postgres?sslmode=require"

# === Optional ===

# Path to frontend build directory for same-origin serving (omit for API-only mode)
# PUBLIC_PATH=../frontend/dist

# Public base URL for OG meta tags (fallback: http://localhost:PORT)
# SITE_URL=https://wps-ranking.com

# Override cache directory for pipeline scripts (default: ./cache)
# CACHE_DIR=./cache

# Override WCA export download URL
# WCA_EXPORT_URL=https://www.worldcubeassociation.org/export/results/WCA_export.tsv.zip
