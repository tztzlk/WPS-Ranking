# Runtime (required)
PORT=5000
NODE_ENV=development
DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true&connection_limit=1"
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Prisma CLI / import scripts (required for generate, migrate, db push, import:data)
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

