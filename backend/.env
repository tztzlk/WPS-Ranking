PORT=5000
NODE_ENV=development
WCA_API_BASE_URL=https://www.worldcubeassociation.org/api/v0
# Transaction pooler (port 6543) — for runtime app only; do not use for Prisma schema operations
DATABASE_URL="postgresql://postgres.gvrgqebaitfxqqhgzsnj:C5aSuxXgDwB8MTwS@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Session-mode pooler (pooler host, port 5432) — for Prisma CLI: db push, migrate, generate.
# Use this if direct db.xxx:5432 is unreachable (e.g. no IPv6). Do NOT use pgbouncer=true here.
DIRECT_DATABASE_URL="postgresql://postgres.gvrgqebaitfxqqhgzsnj:C5aSuxXgDwB8MTwS@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require"
# Set to false to allow self-signed TLS certs (e.g. Supabase pooler). Prefer true in production.
DATABASE_SSL_REJECT_UNAUTHORIZED=false
